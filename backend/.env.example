# Database (Railway provides this automatically if you add a PostgreSQL plugin)
DATABASE_URL=postgresql://user:password@localhost:5432/sdental

# Flask
FLASK_ENV=production
SECRET_KEY=your-secret-key-here
JWT_SECRET_KEY=your-jwt-secret-key-here

# Base URL (your Railway backend URL)
BASE_URL=https://your-app.up.railway.app

# CORS - Frontend URL (comma-separated for multiple origins)
ALLOWED_ORIGINS=https://sdental.pages.dev,http://localhost:3000

# AI provider (OpenRouter - gives access to models from many providers)
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5

# Evolution API (WhatsApp integration)
EVOLUTION_API_URL=https://your-evolution-api.com
EVOLUTION_API_KEY=your-evolution-api-key-here

# Chat pipeline: quiet window (seconds) that groups rapid-fire patient
# messages into a single AI reply. 0 = reply immediately, synchronously.
MESSAGE_AGGREGATION_SECONDS=8
# Audio-capable OpenRouter model used to transcribe patient voice notes
AUDIO_TRANSCRIPTION_MODEL=google/gemini-2.5-flash

# Webhook authentication
WEBHOOK_SECRET=your-webhook-secret-here
# Set to 'true' to disable webhook authentication in development
WEBHOOK_AUTH_DISABLED=false

# Kiwify (subscription billing)
# Same token configured for the webhook in the Kiwify dashboard.
KIWIFY_WEBHOOK_TOKEN=your-kiwify-webhook-token-here
# Checkout link for the SDental subscription product/offer in Kiwify.
KIWIFY_CHECKOUT_URL=https://pay.kiwify.com.br/your-offer-id
# Days a clinic keeps access after a "subscription_late" event before being suspended.
KIWIFY_GRACE_PERIOD_DAYS=5

# Workers (Railway free tier: 2, paid: 4)
WEB_CONCURRENCY=2

# Scheduler (set to 'false' to disable background jobs)
ENABLE_SCHEDULER=true

# Cache and Rate Limiting (optional - uses in-memory by default)
# REDIS_URL=redis://localhost:6379/0
CACHE_TYPE=simple

# Error tracking (optional)
# SENTRY_DSN=https://your-sentry-dsn

# Solo-operator alerts: where platform warnings are sent (AI spend spikes).
# ADMIN_ALERT_EMAIL=voce@seudominio.com
# Daily per-clinic OpenRouter spend (USD) that triggers the alert; 0 disables.
AI_DAILY_COST_ALERT_USD=10
